NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require"
JWT_ACCESS_SECRET="replace-with-a-very-strong-access-secret"
JWT_REFRESH_SECRET="replace-with-a-very-strong-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=10
CORS_ORIGIN="http://localhost:5173,http://localhost:8081,http://localhost:8082"
GMAIL="your-email@gmail.com"
APP_PASSWORD="your-gmail-app-password"
RESEND_API_KEY="re_xxxxxxxxx"
EMAIL_FROM="RoadwayOps Hub <onboarding@yourdomain.com>"
APP_URL="https://roadway-ops-hub.vercel.app"